# === Required ===

# Gateway URL (must match your ar-io-node's internal address)
GATEWAY_URL=http://core:4000

# Must match your ar-io-node's ADMIN_API_KEY (used for block requests)
ADMIN_API_KEY=

# Secret key for the admin dashboard (choose your own, independent of gateway key)
SCANNER_ADMIN_KEY=

# === Scanner Behavior ===

# "dry-run" (log only) or "enforce" (auto-block malicious content)
SCANNER_MODE=dry-run

# Webhook events to process (comma-separated)
# Valid events: data-cached, tx-indexed, ans104-data-item-indexed
# Default: all three. Set to "data-cached" for on-access-only scanning.
# WEBHOOK_EVENTS=data-cached,tx-indexed,ans104-data-item-indexed

# Delay (seconds) before processing indexed events. Gives the gateway's
# data indexer time to save parent bundle relationships so content is
# fetchable via /raw/:id. Set to 0 to process immediately.
# WEBHOOK_INDEX_DELAY=60

# Number of concurrent scan workers
# SCANNER_WORKERS=2

# Port for the scanner HTTP server
# SCANNER_PORT=3100

# Log level: debug, info, warning, error
# LOG_LEVEL=info

# Log format: "text" (human-readable, default) or "json" (for log aggregation)
# LOG_FORMAT=text

# === Detection Tuning ===

# ML phishing model (advisory only — does not block on its own)
# ML_MODEL_ENABLED=true
# ML_SUSPICIOUS_THRESHOLD=0.95

# Individual rule toggles (all enabled by default)
# RULE_SEED_PHRASE=true
# RULE_EXTERNAL_CREDENTIAL_FORM=true
# RULE_WALLET_IMPERSONATION=true
# RULE_OBFUSCATED_LOADER=true
# RULE_FAKE_CHALLENGE=true
# RULE_CREDENTIAL_KIT=true
# RULE_EXTERNAL_SCRIPT_DRAINER=true
# RULE_DRAINER_LOADER=true

# === Rendered DOM Scanning ===

# Two-pass scan: re-render JS-heavy pages in Playwright and re-run rules
# on the rendered DOM. Catches phishing hidden behind JavaScript.
# Requires SCREENSHOT_ENABLED=true (uses the same Playwright browser).
# RENDERED_DOM_SCAN_ENABLED=true

# === Archive Decoding ===

# Decode SingleFile/SingleFileZ web archives (HTML+ZIP polyglots) and scan the
# real page inside, instead of the blank self-extraction wrapper. Guarded
# against zip bombs. Fail-open: on any decode problem the wrapper is scanned.
# ARCHIVE_DECODE_ENABLED=true

# === Content Scanners (Tier 2: pluggable binary content scanning) ===

# Example image scanner (stub, always returns CLEAN — for development/testing)
# SCANNER_EXAMPLE_IMAGE=false

# === Content Limits ===

# Max bytes to read per file (default 256KB)
# MAX_SCAN_BYTES=262144

# Scan timeout in milliseconds
# SCAN_TIMEOUT=10000

# === Admin UI ===

# Disable the admin dashboard (default: enabled)
# ADMIN_UI_ENABLED=true

# Public gateway URL (e.g., https://vilenarios.com).
# Used for clickable TX ID links in the admin dashboard AND for Safe Browsing
# domain monitoring. If not set, TX IDs are plain text and domain monitoring
# is disabled.
# GATEWAY_PUBLIC_URL=

# === Screenshots ===

# Capture screenshots of flagged content for admin review (requires Playwright/Chromium)
# SCREENSHOT_ENABLED=true

# Directory to store screenshot files
# SCREENSHOT_DIR=/app/data/screenshots

# Timeout for page load + screenshot capture in milliseconds
# SCREENSHOT_TIMEOUT_MS=15000

# === Verdict Feed: Share Verdicts with Peer Scanners ===

# API key for the verdict feed (used for both serving and consuming)
# VERDICT_API_KEY=

# Comma-separated URLs of peer content scanners to poll
# VERDICT_FEED_URLS=http://peer1:3100,http://peer2:3100

# Seconds between polling peers for new verdicts
# VERDICT_FEED_POLL_INTERVAL=300

# Trust mode: "malicious_only" (default, safest) or "all"
# VERDICT_FEED_TRUST_MODE=malicious_only

# Check peers on-demand before scanning locally
# VERDICT_FEED_ON_DEMAND=true

# Timeout for peer API requests in milliseconds
# VERDICT_FEED_REQUEST_TIMEOUT_MS=5000

# === Google Safe Browsing ===

# Domain monitoring is automatic — no API key required. The scanner checks your
# gateway domain against Google's Transparency Report every SAFE_BROWSING_CHECK_INTERVAL
# seconds. If your domain is flagged, a warning appears on the admin dashboard.

# Optional: Google Cloud API key with Safe Browsing API enabled.
# When set, the scanner also checks individual flagged content URLs against the
# Safe Browsing Lookup API. SUSPICIOUS verdicts corroborated by Google are
# escalated to MALICIOUS.
# SAFE_BROWSING_API_KEY=

# Seconds between periodic Safe Browsing checks (domain + recent detections)
# SAFE_BROWSING_CHECK_INTERVAL=3600

# === ArNS Gateway Domains ===

# Comma-separated list of gateway domains that serve ArNS names as subdomains.
# Used by email intake to detect ArNS URLs (e.g., angelferno.ar.io) in abuse
# reports and resolve them to TX IDs for scanning.
# Default: ar.io,turbo-gateway.com,ardrive.net,ar-io.dev
# ARNS_GATEWAY_DOMAINS=ar.io,turbo-gateway.com,ardrive.net,ar-io.dev

# === Slack Notifications ===

# Push alerts to Slack when malicious/suspicious content is detected.
# Includes interactive buttons for operators to confirm, dismiss, or classify.

# Enable Slack notifications (requires bot token, channel ID, and signing secret)
# SLACK_ENABLED=false

# Slack Bot OAuth Token (xoxb-...). Create a Slack app at https://api.slack.com/apps
# Required scopes: chat:write, files:write
# SLACK_BOT_TOKEN=

# Slack channel ID (not name) for alerts. Find via: right-click channel → Copy link
# SLACK_CHANNEL_ID=

# Slack Signing Secret (for verifying interactive button callbacks over the
# HTTP request-URL transport). Found in your Slack app's "Basic Information" page.
# SLACK_SIGNING_SECRET=

# Slack App-Level Token (xapp-..., scope connections:write) to handle button
# clicks over Socket Mode — an outbound WebSocket, so no public callback URL is
# needed. Set this and enable Socket Mode + Interactivity in your Slack app.
# Leave unset to use the HTTP request-URL endpoint (POST /api/slack/actions) instead.
# SLACK_APP_TOKEN=

# Notification threshold: "malicious" (default) or "suspicious" (more verbose)
# SLACK_NOTIFICATION_THRESHOLD=malicious

# Burst rollup: during a flood of detections, coalesce auto-blocked (handled)
# alerts into a periodic summary ("98 malicious auto-blocked in the last
# minute") instead of one message each. Alerts that need a human — suspicious
# verdicts, dry-run (still-serving) malicious, and failed blocks — are ALWAYS
# sent individually and never rolled up. Set ENABLED=false for the old
# one-message-per-detection behavior.
# NOTIFICATION_AGGREGATION_ENABLED=true
# Individual alerts until more than this many auto-blocks arrive within the
# window, then coalesce the rest into the rollup.
# NOTIFICATION_AGGREGATION_BURST_THRESHOLD=5
# NOTIFICATION_AGGREGATION_WINDOW_S=60
# How often the pending rollup is flushed to Slack.
# NOTIFICATION_AGGREGATION_FLUSH_INTERVAL_S=60

# === Email Intake (Microsoft 365) ===

# Poll a Microsoft 365 mailbox for abuse reports containing Arweave TX IDs.
# Requires an Azure AD app registration with Mail.ReadWrite application permission.
#
# Setup:
# 1. Register an app in Azure AD (portal.azure.com → App registrations)
# 2. Add API permission: Microsoft Graph → Application → Mail.ReadWrite
# 3. Grant admin consent for the permission
# 4. Create a client secret under Certificates & secrets
# 5. Set the env vars below with your tenant ID, client ID, and client secret

# Enable email intake polling
# EMAIL_INTAKE_ENABLED=false

# Azure AD tenant ID (Directory ID from Azure portal)
# EMAIL_INTAKE_TENANT_ID=

# Azure AD application (client) ID
# EMAIL_INTAKE_CLIENT_ID=

# Azure AD client secret value
# EMAIL_INTAKE_CLIENT_SECRET=

# Mailbox to poll (e.g., abuse@ar.io)
# EMAIL_INTAKE_MAILBOX=

# Seconds between mailbox polls (minimum 10)
# EMAIL_INTAKE_POLL_INTERVAL=60

# === Backfill: Proactive Scan of Existing Cached Content ===

# Enable backfill to scan content already in your gateway's cache
# BACKFILL_ENABLED=false

# Path to your gateway's contiguous data directory
# BACKFILL_DATA_PATH=/gateway-data/contiguous

# Path to gateway's SQLite DB (read-only, for hash→TX ID lookups in enforce mode)
# BACKFILL_GATEWAY_DB_PATH=/gateway-data/sqlite/data.db

# Max files scanned per second during backfill
# BACKFILL_RATE=5

# Hours between re-sweeps (0 = one-shot)
# BACKFILL_INTERVAL_HOURS=24
