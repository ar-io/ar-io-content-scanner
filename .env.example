# Required: must match your ar-io-node's ADMIN_API_KEY
ADMIN_API_KEY=

# Scanner mode: "dry-run" (log only) or "enforce" (auto-block)
SCANNER_MODE=dry-run

# Log level: debug, info, warning, error
LOG_LEVEL=info

# Backfill: proactively scan existing cached content
# BACKFILL_ENABLED=true
# BACKFILL_DATA_PATH=/gateway-data/contiguous
# BACKFILL_GATEWAY_DB_PATH=/gateway-data/sqlite/data.db
# BACKFILL_RATE=5
# BACKFILL_INTERVAL_HOURS=24
